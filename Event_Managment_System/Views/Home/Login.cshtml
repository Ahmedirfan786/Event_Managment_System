@model Event_Managment_System.Models.Users

@if (TempData["InvalidEmail"] != null)
{
    <div class="alert alert-danger">@TempData["InvalidEmail"]</div>
}

@if (TempData["InvalidPassword"] != null)
{
    <div class="alert alert-danger">@TempData["InvalidPassword"]</div>
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h2 class="text-center mb-4">User Login</h2>

            <form asp-action="Login" method="post">

                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <div class="input-group">
                        <input asp-for="PasswordHash" type="password" class="form-control" id="loginPassword" />

                        <button type="button" class="btn btn-outline-secondary" id="toggleLoginPassword">
                            <i class="fa-solid fa-eye" id="loginEyeIcon"></i>
                        </button>
                    </div>

                    <span asp-validation-for="PasswordHash" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary mb-3 w-100">Login</button>

            </form>

        </div>
    </div>
</div>



<script>
    const btn = document.getElementById("toggleLoginPassword");
    const input = document.getElementById("loginPassword");
    const icon = document.getElementById("loginEyeIcon");

    btn.onclick = function () {
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("fa-eye", "fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.replace("fa-eye-slash", "fa-eye");
        }
    };
</script>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}