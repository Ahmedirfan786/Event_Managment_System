@model IEnumerable<Event_Managment_System.Models.Blogs>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-12">

            <h2 class="text-center mb-4">Blogs</h2>

            <div class="row">
                @foreach (var blog in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm">

                            <!-- Image -->
                            <img src="~/Dashboard/BlogImages/@blog.ImagePath"
                                 class="card-img-top"
                                 style="height:200px; object-fit:fill;"
                                 alt="BlogImage">

                            <!-- Card Body -->
                            <div class="card-body d-flex flex-column">

                                <!-- Date -->
                                <small class="text-muted mb-2">
                                    @blog.Date.ToString("dd-MM-yyyy")
                                </small>

                                <!-- Title -->
                                <h5 class="card-title">
                                    @(blog.Title.Length > 35
                                        ? blog.Title.Substring(0, 35) + "..."
                                        : blog.Title)
                                </h5>

                                <!-- Button -->
                                <div class="mt-auto">
                                    <a asp-controller="Home" asp-action="BlogDetail" asp-route-id="@blog.BlogId" class="btn btn-dark w-100">
                                        Read Blog
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
            
        </div>
    </div>

    <div class="d-flex justify-content-center mt-4">
        <nav>
            <ul class="pagination">

                <!-- Previous Button -->
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Blogs"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                        Previous
                    </a>
                </li>

                <!-- Page Numbers -->
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Blogs"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <!-- Next Button -->
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Blogs"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}