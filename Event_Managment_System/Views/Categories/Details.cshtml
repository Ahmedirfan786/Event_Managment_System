@model Event_Managment_System.Models.Categories

@{
    ViewData["Title"] = "Details";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="container-fluid p-4">


    <h1>Details</h1>

    <div>
        <h4>Categories</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Name)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Name)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.ImagePath)
            </dt>
            <dd class="col-sm-10">
                <img src="~/Dashboard/CategoryImages/@Html.DisplayFor(model => model.ImagePath)" width="100px" height="120px" alt="CategoryImage" />
            </dd>
        </dl>
    </div>
    <div>
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model?.CategoryId">Edit</a>
        <a class="btn btn-dark" asp-action="Index">Back to List</a>
    </div>

</div>