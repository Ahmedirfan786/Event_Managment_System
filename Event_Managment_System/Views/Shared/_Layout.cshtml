<!DOCTYPE HTML>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>PWE Wedding & Event Planner</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="~/Website/images/favicon.png" />
    <link rel="stylesheet" href="~/Website/css/animate.css">
    <link rel="stylesheet" href="~/Website/css/themify-icons.css">
    <link rel="stylesheet" href="~/Website/css/bootstrap.css">
    <link rel="stylesheet" href="~/Website/css/magnific-popup.css">
    <link rel="stylesheet" href="~/Website/css/owl.carousel.min.css">
    <link rel="stylesheet" href="~/Website/css/owl.theme.default.min.css">
    <link rel="stylesheet" href="~/Website/css/vegas.slider.min.css">
    <link rel="stylesheet" href="~/Website/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
</head>

<body>
    <!-- Preloader -->
    <div class="preloader-bg"></div>
    <div id="preloader">
        <div id="preloader-status"><div class="preloader-position loader"> <span></span> </div></div>
    </div>
    <!-- Content -->
    <div id="pwe-page">
        <a href="#" class="js-pwe-nav-toggle pwe-nav-toggle"><i></i></a>
        <!-- Sidebar Section -->
        <aside id="pwe-aside">
            <!-- Logo -->
            <h1 id="pwe-logo">
                <a asp-controller="Home" asp-action="Index">EMS<i>®</i><span>Events<small>&#8226;</small> events</span></a>
            </h1>
            <!-- Menu -->
            <nav id="pwe-main-menu">
                <ul>
                    <li class="pwe-active"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Home" asp-action="About">About</a></li>
                    <li><a asp-controller="Home" asp-action="Services">Services</a></li> 
                    <li><a asp-controller="Home" asp-action="Blogs">Blogs</a></li> 
                    <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>

                    @{
                        var adminId = Context.Session.GetInt32("AdminId");
                        var userId = Context.Session.GetInt32("UserId");
                    }

                    @if (adminId == null && userId == null)
                    {
                        <!-- No Admin and No User -->
                        <li>
                            <a class="text-primary" asp-controller="Dashboard" asp-action="Login">
                                Admin Panel
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Home" asp-action="Login" class="text-success">
                                Login
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Home" asp-action="Register" class="text-success">
                                Register
                            </a>
                        </li>
                    }
                    else if (adminId != null)
                    {
                        <!-- Admin Logged In -->
                        <li>
                            <a class="text-success" asp-controller="Dashboard" asp-action="Index">
                                Back to Dashboard (@Context.Session.GetString("AdminName"))
                            </a>
                        </li>
                    }
                    else if (userId != null)
                    {
                        <!-- User Logged In -->
                        <li>
                            <a class="text-warning" asp-controller="Home" asp-action="TrackBookings" asp-route-id="@Context.Session.GetInt32("UserId")">
                                Track Bookings
                            </a>
                        </li>
                        <li>
                            <a class="text-success" asp-controller="Home" asp-action="Index">
                                Welcome (@Context.Session.GetString("UserName"))
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Home" asp-action="ManageProfile" asp-route-id="@Context.Session.GetInt32("UserId")" class="text-success">
                                Manage Profile
                            </a>
                            <a asp-controller="Home" asp-action="Logout" class="text-danger">
                                Logout
                            </a>
                        </li>
                    }
                </ul>
            </nav>
            
            <!-- Sidebar Footer -->
            <div class="pwe-footer">
                <p class="mt-2">
                    +1.123.444.0000
                    <br />info@pweddings.com
                </p>
            </div>
        </aside>
        <!-- Main Section -->
        <div id="pwe-main">

            @RenderBody()

           
            <!-- Footer -->
            <div id="pwe-footer2">
                <div class="pwe-narrow-content">
                    <div class="row">
                        <div class="col-md-4 animate-box" data-animate-effect="fadeInLeft">
                            <h2>
                                <a href="index.html">PWE<i>®</i><span>weddings <small>•</small> events</span></a>
                            </h2>
                            <div class="social"> <a href="#"><i class="ti-facebook"></i></a> <a href="#"><i class="ti-twitter-alt"></i></a> <a href="#"><i class="ti-instagram"></i></a> <a href="#"><i class="ti-pinterest"></i></a> </div>
                        </div>
                        <div class="col-md-4 animate-box" data-animate-effect="fadeInLeft">
                            <h6>Ring</h6>
                            <p>+1.123.444.0000</p>
                            <h6>Write</h6>
                            <p>info@pweddings.com</p>
                        </div>
                        <div class="col-md-4 animate-box" data-animate-effect="fadeInLeft">
                            <h6>Address</h6>
                            <p>
                                Wallaway 5st St Normain
                                <br />New York, USA. 98499
                            </p>
                            <p class="copyright">&copy; 2026. All rights reserved.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- jQuery -->
        <script src="~/Website/js/jquery.min.js"></script>
        <script src="~/Website/js/modernizr-2.6.2.min.js"></script>
        <script src="~/Website/js/jquery.easing.1.3.js"></script>
        <script src="~/Website/js/bootstrap.min.js"></script>
        <script src="~/Website/js/jquery.waypoints.min.js"></script>
        <script src="~/Website/js/sticky-kit.min.js"></script>
        <script src="~/Website/js/jquery.magnific-popup.min.js"></script>
        <script src="~/Website/js/owl.carousel.min.js"></script>
        <script src="~/Website/js/vegas.slider.min.js"></script>
        <script src="~/Website/js/main.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>

        <script type="text/javascript">
            @* Success Message *@
            @if (TempData["SuccessMsg"] != null)
            {
                <text>toastr.success('@TempData["SuccessMsg"]'); </text>
            }

            @* Failure Message *@
            @if (TempData["FailureMsg"] != null)
            {
                <text>toastr.error('@TempData["FailureMsg"]'); </text>
            }

            @* Booking Status Message *@
            @if (TempData["BookingStatus"] != null)
            {
                <text>toastr.info('@TempData["BookingStatus"]'); </text>
            }

        </script>

        @await RenderSectionAsync("Scripts", required: false)   
    </div>
</body>

</html>