<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>Dashboard - SB Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/style.min.css" rel="stylesheet" />
    <link href="~/Dashboard/css/styles.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
</head>
<body class="sb-nav-fixed">
    <nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark">
        <!-- Navbar Brand-->
        <a class="navbar-brand ps-3" href="index.html">Admin Dashboard</a>
        <!-- Sidebar Toggle-->
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0" id="sidebarToggle" href="#!"><i class="fas fa-bars"></i></button>
        <!-- Navbar Search-->
        <form class="d-none d-md-inline-block form-inline ms-auto me-0 me-md-3 my-2 my-md-0">
            <div class="input-group">
                <button asp-controller="Home" asp-action="Index" class="btn btn-light text-dark">
                    Back To Home
                </button>

                <button class="btn btn-warning" id="btnAdminImg" type="button">
                    <img src="@Url.Content("~/Dashboard/AdminImages/" + (ViewBag.AdminImage ?? "default-user.png"))"
                         width="30px" height="30px" alt="profileImg" />
                </button>
                <button class="btn btn-danger" id="btnAdminId" type="button">@ViewBag.AdminId </button>
                <button class="btn btn-primary" id="btnAdminEmail" type="button">@ViewBag.AdminEmail </button>
            </div>
        </form>
        <!-- Navbar-->
        <ul class="navbar-nav ms-auto ms-md-0 me-3 me-lg-4">
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="fas fa-user fa-fw"></i></a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                    <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="ManageProfile">Manage Profile</a></li>
                    <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="Logout">Logout</a></li>
                </ul>
            </li>
        </ul>
    </nav>
    <div id="layoutSidenav">
        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion">
                <div class="sb-sidenav-menu">
                    <div class="nav">
                        <div class="sb-sidenav-menu-heading text-white">Core</div>
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt"></i></div>
                            Dashboard
                        </a>

                        @* Category Links Start *@
                        <div class="sb-sidenav-menu-heading text-white">Events Categories</div>
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseLayouts" aria-expanded="false" aria-controls="collapseLayouts">
                            <div class="sb-nav-link-icon"><i class="fa-solid fa-cake-candles"></i></div>
                            Category
                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse" id="collapseLayouts" aria-labelledby="headingOne" data-bs-parent="#sidenavAccordion">
                            <nav class="sb-sidenav-menu-nested nav">
                                <a class="nav-link" asp-controller="Categories" asp-action="Create">Add Category</a>
                                <a class="nav-link" asp-controller="Categories" asp-action="Index">Display Category</a>
                            </nav>
                        </div>
                        @* Category Links End *@


                        @* Package Links Start *@
                        <div class="sb-sidenav-menu-heading text-white">Event Packages</div>
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseLayouts2" aria-expanded="false" aria-controls="collapseLayouts2">
                            <div class="sb-nav-link-icon"><i class="fa-solid fa-envelope"></i></div>
                            Packages
                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse" id="collapseLayouts2" aria-labelledby="headingOne" data-bs-parent="#sidenavAccordion">
                            <nav class="sb-sidenav-menu-nested nav">
                                <a class="nav-link" asp-controller="Packages" asp-action="Create">Add Package</a>
                                <a class="nav-link" asp-controller="Packages" asp-action="Index">Display Packages</a>
                            </nav>
                        </div>
                        @* Package Links End *@


                        @* Portfolio Links Start *@
                        <div class="sb-sidenav-menu-heading text-white">Event Portfolios</div>
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseLayouts3" aria-expanded="false" aria-controls="collapseLayouts3">
                            <div class="sb-nav-link-icon"><i class="fa-solid fa-star"></i></div>
                            Portfolios
                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse" id="collapseLayouts3" aria-labelledby="headingOne" data-bs-parent="#sidenavAccordion">
                            <nav class="sb-sidenav-menu-nested nav">
                                <a class="nav-link" asp-controller="Portfolios" asp-action="Create">Add Portfolio</a>
                                <a class="nav-link" asp-controller="Portfolios" asp-action="Index">Display Portfolios</a>
                            </nav>
                        </div>
                        @* Portfolio Links End *@

                        @* Booking Links Start *@
                        <div class="sb-sidenav-menu-heading text-white">Event Bookings</div>
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseLayouts4" aria-expanded="false" aria-controls="collapseLayouts4">
                            <div class="sb-nav-link-icon"><i class="fa-solid fa-star"></i></div>
                            Bookings
                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse" id="collapseLayouts4" aria-labelledby="headingOne" data-bs-parent="#sidenavAccordion">
                            <nav class="sb-sidenav-menu-nested nav">
                                <a class="nav-link" asp-controller="Bookings" asp-action="PendingBookings">Pending Bookings</a>
                                <a class="nav-link" asp-controller="Bookings" asp-action="ApprovedBookings">Approved Bookings</a>
                                <a class="nav-link" asp-controller="Bookings" asp-action="RejectedBookings">Rejected Bookings</a>
                                <a class="nav-link" asp-controller="Bookings" asp-action="PaidBookings">Paid Bookings</a>
                                <a class="nav-link" asp-controller="Bookings" asp-action="CompletedBookings">Completed Bookings</a>
                            </nav>
                        </div>
                        @* Booking Links End *@

                        @* Blogs Links Start *@
                        <div class="sb-sidenav-menu-heading text-white">Event Blogs</div>
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseLayouts5" aria-expanded="false" aria-controls="collapseLayouts5">
                            <div class="sb-nav-link-icon"><i class="fa-solid fa-book"></i></div>
                            Blogs
                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse" id="collapseLayouts5" aria-labelledby="headingOne" data-bs-parent="#sidenavAccordion">
                            <nav class="sb-sidenav-menu-nested nav">
                                <a class="nav-link" asp-controller="Blogs" asp-action="Create">Add Blog</a>
                                <a class="nav-link" asp-controller="Blogs" asp-action="Index">Display Blogs</a>
                            </nav>
                        </div>
                        @* Blogs Links End *@

                        @* User Links Start *@
                        <div class="sb-sidenav-menu-heading text-white">Website Users</div>
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseLayouts6" aria-expanded="false" aria-controls="collapseLayouts6">
                            <div class="sb-nav-link-icon"><i class="fa-solid fa-users"></i></div>
                            Users
                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse" id="collapseLayouts6" aria-labelledby="headingOne" data-bs-parent="#sidenavAccordion">
                            <nav class="sb-sidenav-menu-nested nav">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="DisplayUsers">Display Users</a>
                            </nav>
                        </div>
                        @* User Links End *@

                        @* Message Links Start *@
                        <div class="sb-sidenav-menu-heading text-white">Event Messages</div>
                        <a class="nav-link collapsed" href="#" data-bs-toggle="collapse" data-bs-target="#collapseLayouts7" aria-expanded="false" aria-controls="collapseLayouts7">
                            <div class="sb-nav-link-icon"><i class="fa-solid fa-message"></i></div>
                            Messages
                            <div class="sb-sidenav-collapse-arrow"><i class="fas fa-angle-down"></i></div>
                        </a>
                        <div class="collapse" id="collapseLayouts7" aria-labelledby="headingOne" data-bs-parent="#sidenavAccordion">
                            <nav class="sb-sidenav-menu-nested nav">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="DisplayMessages">Display Messages</a>
                            </nav>
                        </div>
                        @* Message Links End *@


                    </div>
                </div>
                <div class="sb-sidenav-footer">
                    <div class="small">Logged in as:</div>
                    <h4 class="text-white">
                        @ViewBag.AdminName
                    </h4>
                </div>
            </nav>
        </div>
        <div id="layoutSidenav_content">

        @RenderBody()
            
        <footer class="py-4 bg-light mt-auto">
                <div class="container-fluid px-4">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted">Copyright &copy; Your Website 2023</div>
                        <div>
                            <a href="#">Privacy Policy</a>
                            &middot;
                            <a href="#">Terms &amp; Conditions</a>
                        </div>
                    </div>
                </div>
        </footer>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/Dashboard/js/scripts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.8.0/Chart.min.js" crossorigin="anonymous"></script>
    <script src="~/Dashboard/assets/demo/chart-area-demo.js"></script>
    <script src="~/Dashboard/assets/demo/chart-bar-demo.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js" crossorigin="anonymous"></script>
    <script src="~/Dashboard/js/datatables-simple-demo.js"></script>
    <script src="https://code.jquery.com/jquery-4.0.0.min.js" integrity="sha256-OaVG6prZf4v69dPg6PhVattBXkcOWQB62pdZ3ORyrao=" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>

    <script type="text/javascript">
        @* Success Message *@
        @if (TempData["SuccessMsg"] != null)
        {
            <text>toastr.success('@TempData["SuccessMsg"]'); </text>
        }

        @* Failure Message *@
        @if (TempData["FailureMsg"] != null)
        {
            <text>toastr.error('@TempData["FailureMsg"]'); </text>
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)


</body>
</html>

