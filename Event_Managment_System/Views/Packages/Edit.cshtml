@model Event_Managment_System.Models.Packages

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="container-fluid p-4">

    <h3>Edit Package</h3>


    <div class="alert alert-danger" asp-validation-summary="ModelOnly">
    </div>

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="PackageId" />

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="price"></label>
            <input asp-for="price" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="CategoryId"></label>
            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
        </div>

        <hr />

        <h4>Package Features</h4>

        <table class="table" id="featureTable">
            <thead>
                <tr>
                    <th>Feature</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>

                @for (int i = 0; i < Model.PackageFeatures.Count; i++)
                {
                    <tr>
                        <td>
                            <input type="hidden" name="PackageFeatures[@i].FeatureId"
                                   value="@Model.PackageFeatures.ElementAt(i).FeatureId" />

                            <input type="hidden" name="PackageFeatures[@i].PackageId"
                                   value="@Model.PackageId" />

                            <input name="PackageFeatures[@i].Name"
                                   value="@Model.PackageFeatures.ElementAt(i).Name"
                                   class="form-control" />
                        </td>

                        <td>
                            <button type="button" class="btn btn-danger removeRow">Remove</button>
                        </td>
                    </tr>
                }

            </tbody>
        </table>

        <button type="button" class="btn btn-success" id="addRow">
            Add Feature
        </button>

        <br /><br />

        <input type="submit" value="Save Changes" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-dark">Back To List</a>

    </form>

</div>



@section Scripts {

<script>

let index = @Model.PackageFeatures.Count;

document.getElementById("addRow").addEventListener("click", function () {

    let table = document.getElementById("featureTable").getElementsByTagName('tbody')[0];

    let row = table.insertRow();

    row.innerHTML =
        `<td>
            <input name="PackageFeatures[${index}].Name" class="form-control"/>
        </td>
        <td>
            <button type="button" class="btn btn-danger removeRow">Remove</button>
        </td>`;

    index++;
});

document.addEventListener("click", function (e) {

    if (e.target.classList.contains("removeRow")) {
        e.target.closest("tr").remove();
    }

});

</script>


    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
