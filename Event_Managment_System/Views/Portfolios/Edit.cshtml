@model Event_Managment_System.Models.Portfolios

@{
    ViewData["Title"] = "Edit Portfolio";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<div class="container-fluid p-4">
    <h1>Edit Portfolio</h1>
    <hr />

    <div class="row">
        <div class="col-md-10">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="PortfolioId" />

                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea rows="10" asp-for="Description" class="form-control"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="EventDate" class="form-label"></label>
                    <input asp-for="EventDate" class="form-control" type="date" />
                    <span asp-validation-for="EventDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Budget" class="form-label"></label>
                    <input asp-for="Budget" class="form-control" />
                    <span asp-validation-for="Budget" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Location" class="form-label"></label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">Main Image</label>
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="mb-2">
                            <img src="@Model.ImagePath" id="currentMainImage" width="180" height="120"
                                 style="object-fit:cover; border-radius:6px; border:2px solid #dee2e6;" />
                        </div>
                    }
                    <input asp-for="Image" type="file" class="form-control" id="mainImageInput" accept=".jpg,.jpeg,.png,.jfif" />
                    <div class="mt-2" id="mainImagePreview"></div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="form-label">Category</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label"><strong>Portfolio Images</strong></label>

                    <div class="row g-3" id="portfolioImagesGrid">
                        @foreach (var img in Model.PortfolioImages)
                        {
                            <div class="col-md-3 col-sm-4 col-6" id="imgCard_@img.PortfolioImageId">
                                <div class="card shadow-sm h-100">
                                    <img src="@img.ImagePath" class="card-img-top"
                                         style="height:130px; object-fit:cover;" id="imgDisplay_@img.PortfolioImageId" />
                                    <div class="card-body text-center p-2 d-flex gap-2 justify-content-center">
                                        <button type="button" class="btn btn-primary btn-sm"
                                                onclick="openEditModal(@img.PortfolioImageId, '@img.ImagePath')">
                                            <i class="fa-solid fa-pen-to-square"></i> Edit
                                        </button>
                                        <button type="button" class="btn btn-danger btn-sm"
                                                onclick="openDeleteModal(@img.PortfolioImageId)">
                                            <i class="fa-solid fa-trash"></i> Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-4">
                        <label class="form-label"><strong>Add More Images</strong></label>
                        <input name="NewAdditionalImages" type="file" class="form-control"
                               id="newAdditionalImagesInput" multiple accept=".jpg,.jpeg,.png,.jfif" />
                        <div class="mt-2 d-flex flex-wrap gap-2" id="newImagesPreview"></div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <input type="submit" value="Save Changes" class="btn btn-success" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editImageModal" tabindex="-1" aria-labelledby="editImageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editImageModalLabel">Replace Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">Current image:</p>
                <img id="editModalCurrentImg" src="" width="100%" height="180"
                     style="object-fit:cover; border-radius:6px;" class="mb-3" />
                <label class="form-label">Select new image:</label>
                <input type="file" class="form-control" id="editImageFileInput" accept=".jpg,.jpeg,.png,.jfif" />
                <div class="mt-2" id="editImageNewPreview"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmEditImageBtn">
                    <span id="editBtnSpinner" class="spinner-border spinner-border-sm d-none me-1"></span>
                    Save Image
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteImageModal" tabindex="-1" aria-labelledby="deleteImageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteImageModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this image? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteImageBtn">
                    <span id="deleteBtnSpinner" class="spinner-border spinner-border-sm d-none me-1"></span>
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentEditImageId = null;
        let currentDeleteImageId = null;

        // ── Main image preview ──────────────────────────────────────────
        document.getElementById('mainImageInput').addEventListener('change', function (e) {
            const preview = document.getElementById('mainImagePreview');
            preview.innerHTML = '';
            const file = e.target.files[0];
            if (file) {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.className = 'img-thumbnail mt-2';
                img.style.maxWidth = '200px';
                preview.appendChild(img);
            }
        });

        // ── New additional images preview ───────────────────────────────
        document.getElementById('newAdditionalImagesInput').addEventListener('change', function (e) {
            const preview = document.getElementById('newImagesPreview');
            preview.innerHTML = '';
            for (let file of e.target.files) {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.className = 'img-thumbnail';
                img.style.cssText = 'width:120px; height:90px; object-fit:cover;';
                preview.appendChild(img);
            }
        });

        // ── EDIT MODAL ──────────────────────────────────────────────────
        function openEditModal(imageId, imagePath) {
            currentEditImageId = imageId;
            document.getElementById('editModalCurrentImg').src = imagePath;
            document.getElementById('editImageFileInput').value = '';
            document.getElementById('editImageNewPreview').innerHTML = '';
            new bootstrap.Modal(document.getElementById('editImageModal')).show();
        }

        // Preview inside edit modal
        document.getElementById('editImageFileInput').addEventListener('change', function (e) {
            const preview = document.getElementById('editImageNewPreview');
            preview.innerHTML = '';
            const file = e.target.files[0];
            if (file) {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.className = 'img-thumbnail mt-2';
                img.style.maxWidth = '100%';
                img.style.maxHeight = '150px';
                preview.appendChild(img);
            }
        });

        document.getElementById('confirmEditImageBtn').addEventListener('click', async function () {
            const fileInput = document.getElementById('editImageFileInput');
            if (!fileInput.files || fileInput.files.length === 0) {
                alert('Please select a new image first.');
                return;
            }

            const spinner = document.getElementById('editBtnSpinner');
            spinner.classList.remove('d-none');
            this.disabled = true;

            const formData = new FormData();
            formData.append('imageId', currentEditImageId);
            formData.append('newImage', fileInput.files[0]);

            try {
                const response = await fetch('@Url.Action("EditPortfolioImage", "Portfolios")', {
                    method: 'POST',
                    body: formData,
                    headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value }
                });
                const result = await response.json();

                if (result.success) {
                    // Update image in the card without page reload
                    document.getElementById('imgDisplay_' + currentEditImageId).src = result.newImagePath + '?t=' + Date.now();
                    bootstrap.Modal.getInstance(document.getElementById('editImageModal')).hide();

                    toastr.success(result.message);

                } else {
                    toastr.error(result.message);
                }
            } catch (e) {
                alert('Something went wrong. Please try again.');
            } finally {
                spinner.classList.add('d-none');
                this.disabled = false;
            }
        });

        // ── DELETE MODAL ────────────────────────────────────────────────
        function openDeleteModal(imageId) {
            currentDeleteImageId = imageId;
            new bootstrap.Modal(document.getElementById('deleteImageModal')).show();
        }

        document.getElementById('confirmDeleteImageBtn').addEventListener('click', async function () {
            const spinner = document.getElementById('deleteBtnSpinner');
            spinner.classList.remove('d-none');
            this.disabled = true;

            const formData = new FormData();
            formData.append('imageId', currentDeleteImageId);

            try {
                const response = await fetch('@Url.Action("DeletePortfolioImage", "Portfolios")', {
                    method: 'POST',
                    body: formData,
                    headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value }
                });
                const result = await response.json();

                if (result.success) {
                    // Remove card from DOM without page reload
                    document.getElementById('imgCard_' + currentDeleteImageId).remove();
                    bootstrap.Modal.getInstance(document.getElementById('deleteImageModal')).hide();
                    toastr.success(result.message);
                } else {
                    toastr.error(result.message);
                }
            } catch (e) {
                alert('Something went wrong. Please try again.');
            } finally {
                spinner.classList.add('d-none');
                this.disabled = false;
            }
        });
    </script>



    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}